{
    "presets": [
        {
            "id": "drive_exposure",
            "name": "Google Drive Exposure",
            "description": "Find publicly shared Google Drive documents, spreadsheets, and folders",
            "category": "cloud_exposure",
            "riskLevel": "medium",
            "icon": "☁️",
            "tags": [
                "cloud",
                "google",
                "documents",
                "sharing"
            ],
            "defaultAST": {
                "type": "ROOT",
                "id": "preset_drive",
                "children": [
                    {
                        "type": "PLATFORM",
                        "id": "p1",
                        "value": "drive"
                    },
                    {
                        "type": "OR",
                        "id": "o1",
                        "children": [
                            {
                                "type": "INURL",
                                "id": "i1",
                                "values": [
                                    "/file/d/",
                                    "/folders/",
                                    "/spreadsheets/d/"
                                ]
                            }
                        ]
                    }
                ],
                "metadata": {
                    "preset": "drive_exposure",
                    "createdAt": ""
                }
            },
            "exampleInputs": [
                "confidential",
                "budget 2024",
                "employee list"
            ],
            "exampleRenderedQuery": "site:drive.google.com (inurl:\"/file/d/\" OR inurl:\"/folders/\" OR inurl:\"/spreadsheets/d/\") \"confidential\""
        },
